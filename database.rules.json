{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$roomId": {
        ".read": "$roomId.matches(/^[A-Z0-9]{6,12}$/)",
        ".write": "$roomId.matches(/^[A-Z0-9]{6,12}$/)"
      }
    },
    "feedback": {
      "$feedbackId": {
        ".read": false,
        ".write": "$feedbackId.matches(/^[a-z0-9]{18}$/)"
      }
    }
  }
}
